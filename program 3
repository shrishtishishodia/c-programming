#include <stdio.h>

// Function to swap two numbers using call by reference
void swap(int *a, int *b)
{
    int temp;
    temp = *a;
    *a = *b;
    *b = temp;
}

int main()
{
    int x = 5, y = 10;

    printf("Before swapping:\n");
    printf("x = %d, y = %d\n", x, y);

    swap(&x, &y);   // passing addresses

    printf("After swapping:\n");
    printf("x = %d, y = %d\n", x, y);

    return 0;
}
