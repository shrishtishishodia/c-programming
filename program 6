#include <stdio.h>
#include <string.h>

/* Function to count frequency of a given character */
int char_freq(char str[], char ch)
{
    int i, count = 0;

    for (i = 0; str[i] != '\0'; i++)
    {
        if (str[i] == ch)
            count++;
    }
    return count;
}

/* Function to count number of words */
int word_count(char str[])
{
    int words = 0;

    // count spaces and add 1
    words = char_freq(str, ' ') + 1;

    return words;
}

int main()
{
    char str[200];
    char ch;
    int i;

    printf("Enter a string: ");
    gets(str);   // used for simplicity (exam use)

    /* Frequency of a character */
    printf("Enter a character to find its frequency: ");
    scanf("%c", &ch);

    printf("Frequency of '%c' = %d\n", ch, char_freq(str, ch));

    /* Word count */
    printf("Number of words = %d\n", word_count(str));

    /* Frequency of each alphabet */
    printf("\nFrequency of each alphabet:\n");
    for (i = 'a'; i <= 'z'; i++)
    {
        int f = char_freq(str, i) + char_freq(str, i - 32); // lower + upper
        if (f > 0)
            printf("%c : %d\n", i, f);
    }

    return 0;
}
