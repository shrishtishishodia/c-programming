#include <stdio.h>
#include <stdlib.h>

/* Function declarations */
void menu(int *ch);
void input(int a[], int *n);
void display(int a[], int n);
int sum_array(int a[], int n);
float avg_array(int a[], int n);
int min_array(int a[], int n);
int max_array(int a[], int n);

int main()
{
    int data[100];
    int ch, num_element = 0;

    while (1)
    {
        menu(&ch);

        switch (ch)
        {
            case 1:
                input(data, &num_element);
                break;

            case 2:
                display(data, num_element);
                printf("Sum of array elements = %d\n",
                       sum_array(data, num_element));
                break;

            case 3:
                display(data, num_element);
                printf("Average of array elements = %.2f\n",
                       avg_array(data, num_element));
                break;

            case 4:
                display(data, num_element);
                printf("Minimum element = %d\n",
                       min_array(data, num_element));
                break;

            case 5:
                display(data, num_element);
                printf("Maximum element = %d\n",
                       max_array(data, num_element));
                break;

            case 6:
                exit(0);

            default:
                printf("Invalid entry\n");
        }
    }

    return 0;
}

/* Menu function */
void menu(int *ch)
{
    printf("\n--- ARRAY OPERATIONS MENU ---\n");
    printf("1. Input Array\n");
    printf("2. Sum of Array\n");
    printf("3. Average of Array\n");
    printf("4. Minimum of Array\n");
    printf("5. Maximum of Array\n");
    printf("6. Exit\n");
    printf("Enter your choice: ");
    scanf("%d", ch);
}

/* Input function */
void input(int a[], int *n)
{
    int i;
    printf("Enter number of elements: ");
    scanf("%d", n);

    for (i = 0; i < *n; i++)
    {
        printf("Enter element %d: ", i + 1);
        scanf("%d", &a[i]);
    }
}

/* Display function */
void display(int a[], int n)
{
    int i;
    printf("Array elements: ");
    for (i = 0; i < n; i++)
    {
        printf("%d ", a[i]);
    }
    printf("\n");
}

/* Sum function */
int sum_array(int a[], int n)
{
    int i, sum = 0;
    for (i = 0; i < n; i++)
    {
        sum += a[i];
    }
    return sum;
}

/* Average function */
float avg_array(int a[], int n)
{
    return (float)sum_array(a, n) / n;
}

/* Minimum function */
int min_array(int a[], int n)
{
    int i, min = a[0];
    for (i = 1; i < n; i++)
    {
        if (a[i] < min)
            min = a[i];
    }
    return min;
}

/* Maximum function */
int max_array(int a[], int n)
{
    int i, max = a[0];
    for (i = 1; i < n; i++)
    {
        if (a[i] > max)
            max = a[i];
    }
    return max;
}
