#include <stdio.h>
#include <string.h>


void printName(char name[])
{
    int i;
    int len = strlen(name);

    printf("%c. ", name[0]);

    
    for (i = 1; i < len; i++)
    {
        if (name[i] == ' ' && name[i + 1] != '\0')
        {
            
            if (strchr(name + i + 1, ' ') != NULL)
                printf("%c. ", name[i + 1]);
            else
            {
                
                printf("%s", name + i + 1);
                break;
            }
        }
    }
}

int main()
{
    char name[100];

    printf("Enter full name: ");
    gets(name);  

    printName(name);

    return 0;
}
